PORT=3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/unleashed_hubspot_sync

# Unleashed
UNLEASHED_API_BASE_URL=https://api.unleashedsoftware.com
UNLEASHED_API_ID=replace_me
UNLEASHED_API_KEY=replace_me
UNLEASHED_WEBHOOK_SIGNATURE_KEY=replace_me
UNLEASHED_CLIENT_TYPE=your_company/unleashed-hubspot-sync

# HubSpot private app token
HUBSPOT_ACCESS_TOKEN=replace_me
HUBSPOT_API_BASE_URL=https://api.hubapi.com

# Processing controls
WORKER_POLL_MS=2000
MAX_ORDER_FETCH_ATTEMPTS=5
ORDER_FETCH_BACKOFF_MS=2000
PROCESS_ONLY_EVENTS_CREATED_AFTER=
AUTO_IGNORE_EVENTS_OLDER_THAN_STARTUP=false
DRY_RUN=false
ALLOW_CONTACT_CREATE_WITHOUT_EMAIL=true
DELETE_MISSING_LINE_ITEMS=false

# HubSpot deal defaults
HUBSPOT_DEAL_PIPELINE=default
HUBSPOT_DEAL_STAGE=appointmentscheduled

# HubSpot custom properties you already use in Make
DEAL_EXTERNAL_ID_PROPERTY=unleashed_order_number
DEAL_GUID_PROPERTY=unleashed_sales_order_guid
LINE_ITEM_EXTERNAL_ID_PROPERTY=unleashed_sales_order_line_guid
LINE_ITEM_ORDER_NUMBER_PROPERTY=unleashed_order_number
CONTACT_FALLBACK_PROPERTY=unleashed_delivery_key1

# Optional extra contact/deal mappings
CONTACT_OWNER_ID=
DEAL_OWNER_ID=

# Local test mode: skip Postgres and process incoming webhook immediately
DISABLE_DATABASE=true
SKIP_WEBHOOK_SIGNATURE_VERIFY=true
